<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="CalendarItem">
        <attr name="applyStroke" format="boolean" />
    </declare-styleable>
    <declare-styleable name="FixedCardView">
        <attr name="fixedAppcompatPadding" format="boolean" />
        <attr name="applyCardBackgroundColor" format="boolean" />
        <attr name="dashboardInnerCard" format="boolean" />
    </declare-styleable>
    <declare-styleable name="ItemCardView">
        <attr name="applyAdditionHorizontalMargin" format="boolean" />
    </declare-styleable>
    <declare-styleable name="LocationContainerView">
        <attr name="displayMode" format="enum">
            <enum name="editing" value="0" />
            <enum name="readOnly" value="1" />
            <enum name="compact" value="2" />
        </attr>
    </declare-styleable>
    <declare-styleable name="FixedTextView">
        <attr name="applyGlobalSize" format="boolean" />
        <attr name="applyGlobalColor" format="boolean" />
        <attr name="applyHighLight" format="boolean" />
        <attr name="applyBoldStyle" format="boolean" />
    </declare-styleable>
</resources>
